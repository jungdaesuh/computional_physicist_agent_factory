    },
    "reason": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "title": "Reason"
    },
    "operator": {
      "title": "Operator",
      "type": "string"
    },
    "invoked_at": {
      "format": "date-time",
      "title": "Invoked At",
      "type": "string"
    }
  },
  "required": [
    "artifact_type",
    "created_at",
    "provenance_hash",
    "event_type",
    "target_id",
    "reason",
    "operator",
    "invoked_at"
